#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../@electron+asar@3.4.1/node_modules/@electron/asar/bin/asar.js" "$@"
else
  exec node  "$basedir/../../../../../@electron+asar@3.4.1/node_modules/@electron/asar/bin/asar.js" "$@"
fi
